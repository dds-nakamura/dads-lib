{
  "name": "dads-lib",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "デジタル庁デザインシステム (DADS) Vue 3 コンポーネントライブラリ monorepo",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r --filter=\"./packages/**\" run test",
    "lint": "echo 'lint not configured yet (Phase 4)'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
