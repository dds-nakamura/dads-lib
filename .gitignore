# Node
node_modules/
*.log
.pnpm-debug.log*
pnpm-debug.log

# Build outputs
dist/
coverage/

# VitePress (monorepo: use **/ so apps/*/.vitepress/ も対象になる)
**/.vitepress/cache
**/.vitepress/dist

# OS
.DS_Store
Thumbs.db

# MCP / agent artifacts
.playwright-mcp/

# Steering workspace (ephemeral specs per Issue / Backlog 課題キー)
# 永続化が必要なドキュメントは docs/ に集約する運用 (CLAUDE.md 参照)。
.steering/

# Claude Code worktrees — /github-issue や手動 `git worktree add` で作る作業用
# linked worktree の置き場所。git は linked worktree を status から除外するが、
# 外部ツール (IDE / lint / find 等) が拾うのを防ぐためここで明示的に無視する。
.claude/worktrees/

# Runtime artifacts from dads-document-html local server
/dads-document-html/.server.pid

# Local env (figma token 等)
.env
.env.local

# Playwright auth state (Figma ログインクッキー)
scripts/.figma-auth.json
test-results/
playwright-report/

# Figma エクスポートの実体は手元生成物。
# 共有が必要なら個別に git add する (manifest.json は版管理してもよい)。
/dads-document-figma/*.png
/dads-document-figma/*.jpg
/dads-document-figma/*.svg
/dads-document-figma/*.pdf
/dads-document-figma/**/*.png
/dads-document-figma/**/*.jpg
/dads-document-figma/**/*.svg
/dads-document-figma/**/*.pdf

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# TypeScript
*.tsbuildinfo

# Vendored upstream clones — exclude internal git state and build artifacts.
# Source files are intentionally tracked (Option A: vendor strategy / D-6).
