/design-tokens/.git
/design-tokens/node_modules
/design-tokens/dist
/tailwind-theme-plugin/.git
/tailwind-theme-plugin/node_modules
/tailwind-theme-plugin/dist
/design-system-example-components-html/.git
/design-system-example-components-html/node_modules
/design-system-example-components-html/dist
